generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

//////////////////////////////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////////////////////////////

enum SchoolType {
  COMMUNITY
  INSTITUTIONAL
  RELIGIOUS
  OTHER
}

enum EducationLevel {
  ECD
  BASIC
  SECONDARY
  BASIC_SECONDARY
}

enum LanguageType {
  ENGLISH
  NEPALI
  BILINGUAL
}

enum Status {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum GenderType {
  MALE
  FEMALE
  OTHER
}

enum AttendanceType {
  FULL_DAY
  HALF_DAY
  LEAVE
  HOLIDAY
}

enum UserType {
  SUPER_ADMIN
  ADMIN
  TEACHER
  STUDENT
  PARENT
  STAFF
}

enum AssessmentType {
  FORMATIVE
  SUMMATIVE
  OBSERVATION
  PRACTICAL
  PROJECT
}

enum RelationshipType {
  FATHER
  MOTHER
  GRANDFATHER
  GRANDMOTHER
  UNCLE
  AUNT
  SIBLING
  LEGAL_GUARDIAN
  OTHER
}

enum AssignmentType {
  CLASS_TEACHER
  SUBJECT_TEACHER
}

enum NotificationChannel {
  SMS
  EMAIL
  WHATSAPP
  PUSH
}

enum NotificationStatus {
  PENDING
  QUEUED
  SENT
  DELIVERED
  FAILED
  RETRYING
  CANCELLED
}

enum NotificationPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

// STUDENT_PHOTO and TEACHER_PHOTO are the single source of truth for profile
// photos (see Student/Employee notes below — no photoUrl duplication).
enum DocumentCategory {
  STUDENT_PHOTO
  TEACHER_PHOTO
  BIRTH_CERTIFICATE
  CITIZENSHIP
  TRANSFER_CERTIFICATE
  CHARACTER_CERTIFICATE
  TEACHER_DOCUMENT
  SCHOOL_DOCUMENT
  OTHER
}

enum DeviceType {
  DESKTOP
  MOBILE
  TABLET
  OTHER
}

enum SettingDataType {
  STRING
  NUMBER
  BOOLEAN
  JSON
}

//////////////////////////////////////////////////////////////////////////////
// MASTER DATA
//////////////////////////////////////////////////////////////////////////////

model MunicipalityType {
  id           String   @id @default(uuid())
  code         String   @unique
  // Official government identifier for this municipality type, used to
  // cross-reference against government/NPC master datasets during seeding
  // and sync. Unique so each government record maps to exactly one row.
  governmentId Int      @unique
  nameEnglish  String
  nameNepali   String?
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @db.Timestamptz(6)

  localLevels LocalLevel[]

  @@index([isActive])
}

model Province {
  id           String   @id @default(uuid())
  code         String   @unique
  // Official government identifier for this province, used to
  // cross-reference against government/NPC master datasets during seeding
  // and sync. Unique so each government record maps to exactly one row.
  governmentId Int      @unique
  nameEnglish  String
  nameNepali   String?
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @db.Timestamptz(6)

  districts District[]
  schools   School[]
  campuses  Campus[]
  students  Student[]
  guardians Guardian[]
  employees Employee[]

  @@index([isActive])
}

model District {
  id           String   @id @default(uuid())
  provinceId   String
  code         String
  // Official government identifier for this district, used to
  // cross-reference against government/NPC master datasets during seeding
  // and sync. Unique so each government record maps to exactly one row.
  governmentId Int      @unique
  nameEnglish  String
  nameNepali   String?
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @db.Timestamptz(6)

  province    Province     @relation(fields: [provinceId], references: [id], onDelete: Restrict)
  localLevels LocalLevel[]
  schools     School[]
  campuses    Campus[]
  students    Student[]
  guardians   Guardian[]
  employees   Employee[]

  @@unique([provinceId, code])
  @@index([isActive])
}

model LocalLevel {
  id                 String   @id @default(uuid())
  districtId         String
  municipalityTypeId String
  code               String
  // Official government identifier for this local level, used to
  // cross-reference against government/NPC master datasets during seeding
  // and sync. Unique so each government record maps to exactly one row.
  governmentId       Int      @unique
  // Total number of wards within this local level.
  totalWards         Int?
  nameEnglish        String
  nameNepali          String?
  displayOrder       Int      @default(0)
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now()) @db.Timestamptz(6)
  updatedAt          DateTime @updatedAt @db.Timestamptz(6)

  district         District         @relation(fields: [districtId], references: [id], onDelete: Restrict)
  municipalityType MunicipalityType @relation(fields: [municipalityTypeId], references: [id], onDelete: Restrict)

  schools   School[]
  campuses  Campus[]
  students  Student[]
  guardians Guardian[]
  employees Employee[]

  @@unique([districtId, code])
  @@index([isActive])
  @@index([municipalityTypeId])
}

model Gender {
  id           String   @id @default(uuid())
  code         String   @unique
  nameEnglish  String
  nameNepali   String?
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now()) @db.Timestamptz(6)
